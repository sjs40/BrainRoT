{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist-electron",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@shared/*": ["./src/shared/*"]
    },
    "types": ["node", "electron"],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src/electron", "src/shared"]
}
